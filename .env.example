# 邮件配置（下面是 QQ 邮箱示例）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
MAIL_FROM=your_email@qq.com
MAIL_TO=your_email@qq.com
SMTP_USE_SSL=true

# 可选：兼容 OpenAI Chat Completions 的模型接口。
# 不填也能发送，但不会自动生成高质量中文摘要。
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=

# auto：有模型就用模型，否则用免费翻译；free：始终用免费翻译；off：保留原文
TRANSLATION_MODE=auto
FULL_ARTICLE_BRIEF=true
BRIEF_MAX_CHARS=2200

# 抓取范围与邮件数量
LOOKBACK_HOURS=36
MAX_ARTICLES=18
MAX_PER_SOURCE=5
REQUEST_TIMEOUT=20
TIMEZONE=Asia/Shanghai
